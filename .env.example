# =============================================================================
# .env — copy to .env and fill in secrets before running
# =============================================================================

# Host Config (set by make set_env)
DGX_IP=

# Verbosity level
LITELLM_VERBOSE=true

TASK_RETRIES=3

# Ports
GITEA_PORT=3000
GITEA_SSH_PORT=2222
MLFLOW_PORT=5000

# Gitea
# TOKEN is auto-generated by 'make setup'
# REPO use the current date and time to avoid collision with previous content --if any-- set during make set_env
GITEA_TOKEN=
GITEA_USER=agent-bot
GITEA_PASSWORD=changeme
GITEA_EMAIL=agent@example.com
GITEA_REPO=

# RALPH_LOOP: Set the number of times the crew should loop (default: 1)
RALPH_LOOP=1

# MLflow
# EXPERIMENT use the same name as the GITEA_REPO --also set using make set_env
MLFLOW_EXPERIMENT_NAME=

# Ollama
OLLAMA_MODEL=qwen3-coder-next:latest
OLLAMA_NUM_CTX=65536

# Sandbox runtime: runsc (gVisor, recommended) or runc (standard Docker)
SANDBOX_RUNTIME=runsc
SANDBOX_MEMORY=4g
SANDBOX_CPUS=4

# WANTED_UID and WANTED_GID are set automatically in the Makefile
